# ==============================================================================
# LifePilot AI - Production Environment Configurations Example
# Copy this file to .env in production environment and adjust values.
# ==============================================================================

# Core Application Settings
PROJECT_NAME="LifePilot AI"
ENVIRONMENT=production
DEBUG=false
# IMPORTANT: Provide a secure, random hex string in production! (minimum 32 chars)
SECRET_KEY=e831f2b6a718c0e2d093bfa56c4d7e8f90a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5
LOG_LEVEL=info

# Frontend Configurations
NEXT_PUBLIC_API_URL=https://your-backend-service.onrender.com

# Backend Configurations
BACKEND_PORT=8000
# IMPORTANT: Set strict CORS origins in production!
CORS_ORIGINS=https://your-frontend-app.vercel.app

# Database & Redis Settings
# Note: Use rediss:// (with double 's') for secure TLS Redis connections in production.
DATABASE_URL=postgresql+asyncpg://production_user:production_secure_pass_here@production-db-host.render.com:5432/production_db
REDIS_URL=rediss://:production_redis_pass_here@production-redis-host.render.com:6379/0

# Vector & Knowledge Configurations
EMBEDDING_PROVIDER=sentence-transformers/all-MiniLM-L6-v2
VECTOR_PROVIDER=chroma
KNOWLEDGE_MAX_FILE_SIZE_MB=25
