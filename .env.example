# ==============================================================================
# LifePilot AI - Environment Configurations Example
# Copy this file to .env in the same directory and adjust values.
# ==============================================================================

# ------------------------------------------------------------------------------
# PROJECT CONFIGURATION
# ------------------------------------------------------------------------------
PROJECT_NAME="LifePilot AI"
ENVIRONMENT=development  # development, staging, production
DEBUG=true

# ------------------------------------------------------------------------------
# FRONTEND CONFIGURATIONS (Next.js)
# ------------------------------------------------------------------------------
# Next.js public environment variables must be prefixed with NEXT_PUBLIC_
NEXT_PUBLIC_API_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# BACKEND CONFIGURATIONS (FastAPI)
# ------------------------------------------------------------------------------
BACKEND_PORT=8000
# JSON-formatted list or comma-separated list of origins for CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ------------------------------------------------------------------------------
# DATABASE CONFIGURATIONS (PostgreSQL)
# ------------------------------------------------------------------------------
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lifepilot_user
POSTGRES_PASSWORD=lifepilot_secure_password_replace_me
POSTGRES_DB=lifepilot_db

# ------------------------------------------------------------------------------
# CACHE CONFIGURATIONS (Redis)
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password_replace_me
