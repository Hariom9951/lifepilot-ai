# ==============================================================================
# LifePilot AI - Environment Configurations Example (Development / Local)
# Copy this file to .env in the same directory and adjust values.
# ==============================================================================

# Core Application Settings
PROJECT_NAME="LifePilot AI"
ENVIRONMENT=local
DEBUG=true
SECRET_KEY=replace_me_with_a_secure_random_hex_string_sprinting_phase
LOG_LEVEL=debug

# Frontend Configurations
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend Configurations
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Database & Redis Settings
DATABASE_URL=postgresql+asyncpg://lifepilot_user:lifepilot_secure_password_replace_me@localhost:5432/lifepilot_db
REDIS_URL=redis://:redis_secure_password_replace_me@localhost:6379/0

# Vector & Knowledge Configurations
EMBEDDING_PROVIDER=mock
VECTOR_PROVIDER=chroma
KNOWLEDGE_MAX_FILE_SIZE_MB=25
